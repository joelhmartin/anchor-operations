# ============================================================================
# anchor-ops — environment configuration
# ============================================================================
# In production these come from Secret Manager (mounted by Cloud Run — see
# infra/provision-ops.sh). Locally, copy this to `.env` and fill in.
#
# CRITICAL (see the three-app integration plan, §1 + "Gotchas"):
#   ENCRYPTION_KEY and JWT_SECRET MUST be byte-identical to the main app
#   (anchor-hub). Different AES key => can't decrypt oauth_connections /
#   client_platform_credentials. Different JWT secret => SSO breaks (a token
#   minted by the main app's login won't validate here).

# ---- Core ----
NODE_ENV=development
PORT=4000
# Set true to run the ops migrations on server start (prod). Locally, prefer
# `yarn db:migrate` instead so a slow/failed migration never blocks dev boot.
RUN_MIGRATIONS_ON_START=false

# ---- Database (shared Cloud SQL `anchor`; ops connects as the ops_app role) ----
# Local dev points at your local Postgres. Prod uses the `anchor-db-url-ops`
# secret (ops_app role — SELECT on client tables, DML on the ops schema).
DATABASE_URL=postgresql://bif@localhost:5432/anchor

# ---- Shared secrets — MUST match anchor-hub ----
ENCRYPTION_KEY=
JWT_SECRET=

# ---- CORS / app URLs ----
CORS_ORIGINS=http://localhost:3000,http://localhost:4173
APP_BASE_URL=http://localhost:3000

# ---- Agency API credentials (read from the shared Secret Manager in prod) ----
# Google Ads (gRPC via google-ads-api — REST 404s)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_MANAGER_ID=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
# Meta (system user token). HIPAA gate: Meta checks skip client_type='medical'.
FACEBOOK_SYSTEM_USER_TOKEN=
# --- Content suite (social publishing, ported from main app) ---
# FACEBOOK_SYSTEM_USER_TOKEN + ENCRYPTION_KEY (required above) are reused.
# The two below are additionally required for media + token signing:
SOCIAL_MEDIA_SECRET=             # HMAC secret for signed media tokens — MUST match anchor-hub value
VIMEO_ACCESS_TOKEN=              # Resolve Vimeo direct file URLs for video posts
# Kinsta (WordPress site ops / SSH)
KINSTA_API_KEY=
KINSTA_USER=
KINSTA_USER_PASSWORD=
KINSTA_AGENCY_ID=
# CTM (call-tracking health checks)
CTM_API_KEY=
CTM_API_SECRET=
CTM_API_BASE=https://api.calltrackingmetrics.com
# Mailgun (run digests / subscription emails)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_DEFAULT_FROM=
# GA4 / Search Console / GTM service account JSON (or use ADC on Cloud Run)
GA4_SERVICE_ACCOUNT_KEY=
GOOGLE_APPLICATION_CREDENTIALS=

# ---- Vertex AI (supervisor + sub-agents). Cloud Run uses ADC automatically. ----
GOOGLE_CLOUD_PROJECT=anchor-hub-480305
GOOGLE_CLOUD_REGION=us-central1
VERTEX_PROJECT_ID=anchor-hub-480305
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-2.0-flash
OPERATIONS_AGENT_MODEL=gemini-2.0-flash

# ---- Pro AI chat (Claude) ----
ANTHROPIC_API_KEY=          # first-party Anthropic API key (chat runtime). Same secret as Secret Manager.
OPS_CHAT_DEFAULT_MODEL=     # optional override of the supervisor default (claude-sonnet-4-6)

# ---- Website-check provider keys (checks skip gracefully if unset) ----
PSI_API_KEY=
PSI_DAILY_QUOTA=25000
SEMRUSH_API_KEY=
WPSCAN_API_TOKEN=

# ---- Ops orchestration ----
# GCS bucket for rendered HTML reports (signed URLs).
OPS_REPORTS_BUCKET=
# Shared secret + allowed service accounts for the Cloud Scheduler -> fan-out call.
OPS_FANOUT_SHARED_SECRET=
OPS_FANOUT_ALLOWED_SAS=
# Pub/Sub subscription the runner Job consumes.
OPS_RUN_SUBSCRIPTION=ops-runner
OPS_RUNNER_CONCURRENCY=4
# Portfolio digest recipients (comma-separated).
OPS_ADMIN_DIGEST_RECIPIENTS=
# Report renderer signing secret (shared with anchor-hub if reports are cross-linked).
REPORT_RENDER_SECRET=
